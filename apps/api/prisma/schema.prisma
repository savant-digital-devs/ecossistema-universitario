generator client {
  provider = "prisma-client"
  output   = "../src/infra/database/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  cpf          String   @unique
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}